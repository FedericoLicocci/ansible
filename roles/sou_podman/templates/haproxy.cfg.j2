global
    maxconn 20000
    ulimit-n 16384
    log 127.0.0.1 local0
    daemon

frontend fe_https
    bind *:8443 ssl crt /usr/local/etc/haproxy/certs/haproxy_cert.pem
    mode http
    log global
    option httplog
    option dontlognull
    option nolinger
    maxconn 8000
    timeout client 30s
    
    acl is_grafana hdr_dom(host) -i foobar.local
    use_backend grafana if is_grafana
    
    acl is_prometheus hdr_dom(host) -i foo.local
    use_backend prometheus if is_prometheus

backend vault
    mode http
    balance roundrobin
    timeout connect 60s
    timeout server 60s

backend grafana
    mode http
    balance roundrobin
    server grafana grafana:3000 check inter 10s fall 5 
    timeout connect 60s
    timeout server 60s 

backend prometheus
    mode http
    balance roundrobin
    server prometheus prometheus:9090 check inter 10s fall 5
    timeout connect 60s
    timeout server 60s

listen stats
    bind *:1936
    mode http
    stats enable
    stats uri /
    stats refresh 5s
